###############Seller and Super Admin Backend ###############

# MongoDB
MONGO_URL="mongodb+srv://<username>:<password>@<cluster>.mongodb.net/Trialshopy"

# JWT
JWT_SECRET=<your_jwt_secret>
JWT_EXPIRE=5d
COOKIE_EXPIRE=5

# SMTP (Email notifications)
SMTP_SERVICE=gmail
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_EMAIL=<your_smtp_email>
SMTP_PASSWORD=<your_smtp_app_password>

# Cloudinary
CLOUDINARY_NAME=<your_cloudinary_cloud_name>
CLOUDINARY_API_KEY=<your_cloudinary_api_key>
CLOUDINARY_API_SECRET=<your_cloudinary_api_secret>
CLOUDINARY_URL=cloudinary://<api_key>:<api_secret>@<cloud_name>

# Frontend URL (CORS)
Frontend_Endpoint='http://localhost:7001'

# OpenAI / GitHub Models API Key
OPENAI_API_KEY=<your_openai_or_github_models_api_key>

# Server Port
PORT=5000

# Twilio (OTP / SMS)
TWILIO_ACCOUNT_SID=<your_twilio_account_sid>
TWILIO_AUTH_TOKEN=<your_twilio_auth_token>
TWILIO_FROM_NUMBER=<your_twilio_phone_number>
